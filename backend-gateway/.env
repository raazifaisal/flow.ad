# ==============================================================================
# BHARATFLOW ENGINE - ENVIRONMENT CONFIGURATION
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. GOOGLE GENAI SERVICES
# ------------------------------------------------------------------------------
# Note: The SDK automatically picks up GEMINI_API_KEY. Keep this populated with your key.
GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE
# Models In Use:
# - Swarm Agent Enclave:   'antigravity-preview-05-2026' (remote remote interactions sandbox)
# - Real-time Live Session: 'gemini-3.1-flash-live-preview'
# - Layout Render Engine:   'imagen-3.0-generate-002' (NB2 Lite equivalent)
# - QA Supervisor Loop:    'gemini-3.5-flash'

# ------------------------------------------------------------------------------
# 2. OMNICHANNEL DISTRIBUTION NETWORKS
# ------------------------------------------------------------------------------

# WhatsApp Business Integration
WHATSAPP_API_TOKEN=YOUR_WHATSAPP_BUSINESS_API_TOKEN
WHATSAPP_PHONE_NUMBER_ID=YOUR_WHATSAPP_PHONE_NUMBER_ID

# Meta Graph Integration (Facebook Marketplace & Instagram Reels)
META_ACCESS_TOKEN=YOUR_META_GRAPH_ACCESS_TOKEN
INSTAGRAM_ACCOUNT_ID=YOUR_INSTAGRAM_PROFESSIONAL_ACCOUNT_ID

# Google Maps API Grounding & Promotion
GOOGLE_MAPS_API_KEY=YOUR_GMAP_KEY_HERE
